# Server
NODE_ENV=development
PORT=5000
# DB_SYNC_ALTER=true enables Sequelize alter sync in dev (can fail on MySQL with ER_TOO_MANY_KEYS — use migrations instead)
# لربط المتصفّح من هاتف على نفس الـWi‑Fi: اتركه أو استخدم BIND_HOST=0.0.0.0 (الافتراضي في الكود). للقيود: BIND_HOST=127.0.0.1
# BIND_HOST=0.0.0.0
FRONTEND_URL=http://localhost:5173

# Database
DB_HOST=localhost
DB_PORT=3306
DB_NAME=miskwear_db
DB_USER=root
DB_PASSWORD=your_password

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_in_production
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=your_refresh_token_secret
JWT_REFRESH_EXPIRES_IN=30d

# Cloudinary
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Stripe
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# Paymob (optional — prefer Admin → Settings)
# Modern Intention API:
# PAYMOB_PUBLIC_KEY=egy_pk_test_...
# PAYMOB_SECRET_KEY=egy_sk_test_...
# PAYMOB_HMAC_SECRET=
# Legacy iframe API:
# PAYMOB_API_KEY=
# PAYMOB_INTEGRATION_ID=
# PAYMOB_IFRAME_ID=
# PAYMOB_API_BASE=https://accept.paymob.com/api
# Public API URL for Paymob callbacks (production: https://theboutiqueline.com)
# BACKEND_URL=http://127.0.0.1:5001

# Email (Nodemailer). You can override all of these from Admin → Settings (stored in DB).
# Use SMTP_SECURE=true for implicit TLS (often port 465). Leave unset for STARTTLS on 587.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
SMTP_SECURE=
EMAIL_FROM=noreply@miskwear.com

# Admin
ADMIN_EMAIL=admin@theboutiqueline.com
ADMIN_PASSWORD=Admin@123456

# Marketing integrations + WhatsApp Cloud API credentials (AES-256-GCM at rest — 64 hex chars = 32 bytes).
# Required to save encrypted tokens locally. Generate: openssl rand -hex 32
MARKETING_ENCRYPTION_KEY=

# WhatsApp Cloud API template messages (defaults to v21.0 when unset)
# WHATSAPP_GRAPH_VERSION=v21.0

# Fallback country calling code for outbound template "to" (digits only), if admin DB field is unset. Prefer configuring in Admin → WhatsApp → Country code.
# WHATSAPP_DEFAULT_COUNTRY_CODE=966
# Meta Graph API (optional override)
META_GRAPH_VERSION=v21.0

# Retry worker (unset = enabled). Interval in milliseconds.
MARKETING_QUEUE_INTERVAL_MS=45000
MARKETING_QUEUE_WORKER_DISABLED=false

# Optional inbound marketing webhooks verification header
MARKETING_WEBHOOK_SECRET=

APP_CURRENCY_DEFAULT=SAR

# Custom domain (DNS panel instructions + verification)
# CNAME target shoppers should point the store hostname to (e.g. app.onrender.com):
DOMAIN_DNS_CNAME_TARGET=
# Optional: if using A record @ to your server, put the public IPv4 here:
DOMAIN_DNS_A_RECORD=
